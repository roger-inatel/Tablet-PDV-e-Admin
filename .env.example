# Copie este arquivo para .env (ou .env.local, que tem prioridade) e preencha
# com as credenciais do seu ambiente. NUNCA versione o arquivo preenchido.

# Banco SQL Server do ERP (catalogo de produtos, gravacao de pedidos pagos,
# painel gerencial e auditoria de remocoes).
# Local, via container:
#   docker run -d --name mesaplus-sql -e "ACCEPT_EULA=Y" \
#     -e "MSSQL_SA_PASSWORD=<senha>" -p 1433:1433 \
#     mcr.microsoft.com/mssql/server:2022-latest
DATABASE_URL="sqlserver://localhost:1433;database=DB_POWER_SYS;user=sa;password=<senha>;encrypt=true;trustServerCertificate=true"

# Tabela de preco usada pelo catalogo (TB_TABELA_VENDA_PRECO.ID_TABELA_VENDA).
# Precisa ser a mesma tabela referenciada em src/lib/erp/constants.ts
# (TABELA_VENDA_ID), senao o catalogo mostra preco 0 e a gravacao do pedido
# falha por falta de preco cadastrado.
PRODUCTS_PRICE_TABELA_VENDA_ID=1
